# ─── Platform DB (central: TenantRegistry, HubProperty, billing) ─────────────
PLATFORM_DATABASE_URL=postgresql://inmob:inmob_pass@localhost:5432/inmob_platform

# ─── Tenant DB (dev local — la DB del tenant demo) ───────────────────────────
DATABASE_URL=postgresql://inmob:inmob_pass@localhost:5432/inmob_db

# ─── Auth JWT ────────────────────────────────────────────────────────────────
APP_SECRET=dev-secret-inmob-change-in-production-32chars
JWT_EXPIRY=7d

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_DOMAIN=inmob.com

CORS_ORIGIN=http://localhost:5173

# ─── Licencias ───────────────────────────────────────────────────────────────
TRIAL_DAYS=30

# ─── Neon (provisioning de nuevas DBs) ───────────────────────────────────────
# NEON_API_KEY=neon_api_xxx
# NEON_PROJECT_ID=xxx-project-id
# NEON_DB_OWNER=neondb_owner
# NEON_BASE_URL=postgresql://user:pass@ep-xxx.neon.tech:5432

# ─── Pagos ───────────────────────────────────────────────────────────────────
