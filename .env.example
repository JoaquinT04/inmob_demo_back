# ─── PostgreSQL (docker-compose) ─────────────────────────────────────────────
POSTGRES_USER=inmob
POSTGRES_PASSWORD=inmob_pass
POSTGRES_DB=inmob_platform

# ─── Platform DB ─────────────────────────────────────────────────────────────
# En Docker: host = nombre del servicio (postgres). El compose lo sobreescribe.
# En local sin Docker: localhost
PLATFORM_DATABASE_URL=postgresql://inmob:inmob_pass@localhost:5432/inmob_platform

# Admin connection para crear DBs de tenants (sin nombre de DB al final)
# En Docker: el compose lo sobreescribe con host=postgres automáticamente
POSTGRES_ADMIN_URL=postgresql://inmob:inmob_pass@localhost:5432

# ─── Auth JWT ────────────────────────────────────────────────────────────────
# Producción: openssl rand -hex 32
APP_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRY=7d
# Producción: openssl rand -hex 32
TOKEN_HMAC_SECRET=REPLACE_WITH_openssl_rand_hex_32

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_DOMAIN=tudominio.com

CORS_ORIGIN=http://localhost:5173

# ─── Licencias ───────────────────────────────────────────────────────────────
TRIAL_DAYS=30

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@tudominio.com

# ─── Pagos ───────────────────────────────────────────────────────────────────
# MP_ACCESS_TOKEN=APP_USR-xxx
# MP_WEBHOOK_SECRET=xxx
# MP_BACK_URL=https://tudominio.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crear en: console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# Authorized redirect URI: https://api.tudominio.com/api/auth/google/callback
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ─── Redis ────────────────────────────────────────────────────────────────────
# Producción: openssl rand -hex 16
REDIS_PASSWORD=REPLACE_WITH_openssl_rand_hex_16
REDIS_URL=redis://:REPLACE_WITH_openssl_rand_hex_16@redis:6379
