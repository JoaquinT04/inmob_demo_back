# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://inmob:inmob_pass@localhost:5432/inmob_db

# ─── Auth JWT ────────────────────────────────────────────────────────────────
# Clave para firmar los JWT. Mínimo 32 caracteres. CAMBIAR en producción.
APP_SECRET=dev-secret-inmob-change-in-production-32chars

# Expiración del token JWT (7d, 24h, 30d, etc.)
JWT_EXPIRY=7d

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Origen permitido para CORS. Múltiples separados por coma.
CORS_ORIGIN=http://localhost:5173

# Tenant de desarrollo (slug del tenant creado por el seed)
DEV_TENANT_SLUG=inmob-demo

# ─── Licencias ───────────────────────────────────────────────────────────────
# Duración del período de prueba gratuito en días
TRIAL_DAYS=14

# ─── Pagos ───────────────────────────────────────────────────────────────────
# Stripe (recomendado para producción)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# MercadoPago (alternativa para Argentina)
# MP_ACCESS_TOKEN=APP_USR-xxx
# MP_WEBHOOK_SECRET=xxx

# ─── Auth externo (futuro — no requerido en MVP) ──────────────────────────────
# Para agregar Clerk: descomentar y configurar
# CLERK_SECRET_KEY=sk_test_xxx

# Para agregar Auth0: descomentar y configurar
# AUTH0_DOMAIN=xxx.us.auth0.com
# AUTH0_CLIENT_ID=xxx
# AUTH0_CLIENT_SECRET=xxx
