{
  "name": "@inmob/api",
  "version": "0.1.0",
  "private": true,
  "description": "API backend — Fastify + MikroORM + JWT nativo",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsc -p tsconfig.build.json && node --env-file=../../.env dist/index.js\"",
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "pnpm --filter @inmob/shared build && pnpm --filter @inmob/database build",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@inmob/database": "workspace:*",
    "@inmob/shared": "workspace:*",
    "@mikro-orm/core": "^6.4.3",
    "@mikro-orm/postgresql": "^6.4.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "jose": "^6.2.2",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  }
}
